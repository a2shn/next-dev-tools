{
    "compilerOptions": {
          "target": "ESNext",
              "jsx": "react-jsx",
                  "lib": [
                          "ESNext",
                                "DOM",
                                      "DOM.Iterable"
                                          ],
                                              "baseUrl": ".",
                                                  "module": "ESNext",
                                                      "moduleResolution": "Node",
                                                          "paths": {
                                                                  "@/*": [
                                                                            "src/*"
                                                                                  ]
                                                                                      },
                                                                                          "noFallthroughCasesInSwitch": true,
                                                                                              "noUncheckedIndexedAccess": true,
                                                                                                  "noUnusedLocals": true,
                                                                                                      "noUnusedParameters": true,
                                                                                                          "forceConsistentCasingInFileNames": true,
                                                                                                              "isolatedModules": true,
                                                                                                                  "skipLibCheck": true
                                                                                                                    },
                                                                                                                      "include": [
                                                                                                                            "src"
                                                                                                                              ],
                                                                                                                                "exclude": [
                                                                                                                                      "node_modules",
                                                                                                                                          "dist"
                                                                                                                                            ]
}
